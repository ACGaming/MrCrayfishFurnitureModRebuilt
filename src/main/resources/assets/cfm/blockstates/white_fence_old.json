{
  "multipart": [
    {
      "when": { "post": "true" },
      "apply": { "model": "cfm:white_fence_none_pre_old" }
    },
    {
      "when": { "north": "true", "east": "false", "south": "false", "west": "false" },
      "apply": { "model": "cfm:white_fence_one_pre_old" }
    },
    {
      "when": { "north": "false", "east": "true", "south": "false", "west": "false" },
      "apply": { "model": "cfm:white_fence_one_pre_old", "y": 90 }
    },
    {
      "when": { "north": "false", "east": "false", "south": "true", "west": "false" },
      "apply": { "model": "cfm:white_fence_one_pre_old", "y": 180 }
    },
    {
      "when": { "north": "false", "east": "false", "south": "false", "west": "true" },
      "apply": { "model": "cfm:white_fence_one_pre_old", "y": 270 }
    },
    {
      "when": { "north": "true", "east": "true" },
      "apply": { "model": "cfm:white_fence_two_pre_old" }
    },
    {
      "when": { "north": "true", "south": "true" },
      "apply": { "model": "cfm:white_fence_two_alt_pre_old" }
    },
    {
      "when": { "east": "true", "south": "true" },
      "apply": { "model": "cfm:white_fence_two_alt_pre_old", "y": 90 }
    },
    {
      "when": { "south": "true", "west": "true" },
      "apply": { "model": "cfm:white_fence_two_pre_old", "y": 180 }
    },
    {
      "when": { "north": "true", "west": "true" },
      "apply": { "model": "cfm:white_fence_two_alt_pre_old", "y": 270 }
    },
    {
      "when": { "north": "true", "east": "true", "south": "true" },
      "apply": { "model": "cfm:white_fence_three_pre_old" }
    },
    {
      "when": { "north": "true", "east": "true", "west": "true" },
      "apply": { "model": "cfm:white_fence_three_pre_old", "y": 270 }
    },
    {
      "when": { "east": "true", "south": "true", "west": "true" },
      "apply": { "model": "cfm:white_fence_three_pre_old", "y": 90 }
    },
    {
      "when": { "north": "true", "south": "true", "west": "true" },
      "apply": { "model": "cfm:white_fence_three_pre_old", "y": 180 }
    },
    {
      "when": { "north": "true", "east": "true", "south": "true", "west": "true" },
      "apply": { "model": "cfm:white_fence_four_pre_old" }
    }
  ]
}